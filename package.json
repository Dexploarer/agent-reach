{
  "name": "agent-reach",
  "version": "1.3.0",
  "description": "Give your AI Agent eyes to see the entire internet. Search + Read platforms.",
  "main": "dist/core.js",
  "types": "dist/core.d.ts",
  "bin": {
    "agent-reach-ts": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai-agent",
    "llm-tools",
    "agent-infrastructure",
    "mcp",
    "web-reader",
    "search",
    "youtube",
    "reddit",
    "github",
    "linkedin",
    "rss",
    "twitter",
    "typescript"
  ],
  "author": "Neo Reid",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.ts",
      "**/tests/**/*.ts"
    ]
  }
}
